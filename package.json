{
  "name": "zhiban",
  "version": "0.2.0",
  "description": "知伴 — 论文伴读系统",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "typecheck": "tsc --noEmit",
    "restart": "bash scripts/dev-restart.sh",
    "build:sidecar": "bash scripts/build-sidecar.sh",
    "build:web": "vite build --config vite.config.web.ts",
    "dev:web": "vite --config vite.config.web.ts",
    "start:web": "bash start-webui.sh",
    "build:mac": "vite build && electron-builder --mac --arm64",
    "build:dist": "npm run build:sidecar && npm run build:mac"
  },
  "dependencies": {
    "katex": "^0.17.0",
    "mammoth": "^1.8.0",
    "pdfjs-dist": "^4.10.38",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.0",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "playwright": "^1.60.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
